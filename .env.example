# Backend / AI
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4-flash
OPENAI_FALLBACK_MODEL=glm-4-flash
OPENAI_TIMEOUT_MS=25000
BACKEND_PORT=8080

# Database
POSTGRES_DB=cyber_guide
POSTGRES_USER=cyber_guide
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# Email code (optional, default disabled for local dev)
EMAIL_CODE_ENABLED=false
EMAIL_CODE_DEV_LOG_ONLY=true
EMAIL_CODE_FROM=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback
GITHUB_FRONTEND_CALLBACK=http://localhost:3000
GITHUB_ALLOWED_REDIRECT_ORIGINS=http://localhost:3000

# Frontend -> Backend proxy inside Docker/SSR
INTERNAL_API_BASE_URL=http://backend:8080

# Backend CORS allowlist (comma-separated origin patterns)
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,https://*.cyberguide.dev

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Crawler
CRAWLER_ENABLED=true
CRAWLER_INTERVAL_MINUTES=360
CRAWLER_MAX_PAGES_PER_SOURCE=10
AI_EXTRACT_ENABLED=true
# 若用 bash `source .env` 注入环境变量：Cookie、逗号分隔关键词中含空格（如 CS PhD）或含 | 时，
# 请用单引号包裹整段值，否则 shell 会拆词或把 | 当管道。
ZHIHU_COOKIE=
ZHIHU_EXTRA_QUERIES=
XHS_COOKIE=
XHS_MAX_PER_QUERY=20
XHS_EXTRA_QUERIES=

# Concurrency tuning (optional)
# CHAT_MAX_INFLIGHT=90
# STREAM_MAX_INFLIGHT=20
# TOMCAT_THREADS_MAX=300
# DB_POOL_MAX=30
# REDIS_POOL_MAX_ACTIVE=48

# Chat debug log (local troubleshooting only)
# DEBUG_CHAT_LOG_ENABLED=false
# DEBUG_CHAT_LOG_MAX_CHARS=1200
# DEBUG_CHAT_LOG_ALLOWED_PROFILES=local,dev,test
# DEBUG_CHAT_LOG_SESSION_ID=
# DEBUG_CHAT_LOG_SAMPLE_RATE=1.0
